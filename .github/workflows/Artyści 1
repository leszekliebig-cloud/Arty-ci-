// ══════════════════════════════════════
// FIRE CANVAS ANIMATION
// ══════════════════════════════════════
class FireCanvas {
  constructor(canvas) {
    this.canvas = canvas;
    this.ctx = canvas.getContext('2d');
    this.running = false;
    this.init();
  }
  init() {
    const r = this.canvas.getBoundingClientRect();
    this.w = this.canvas.width  = Math.max(r.width,  10);
    this.h = this.canvas.height = Math.max(r.height, 10);
    this.cols = Math.ceil(this.w / 3);
    this.rows = Math.ceil(this.h / 3);
    this.buf  = new Float32Array(this.cols * (this.rows + 3));
    this.palette = this.buildPalette();
  }
  buildPalette() {
    const p = new Uint8Array(256 * 3);
    for (let i = 0; i < 256; i++) {
      let r, g, b;
      if      (i < 85)  { r = i * 3;         g = 0;               b = 0; }
      else if (i < 170) { r = 255;            g = (i - 85) * 3;   b = 0; }
      else               { r = 255;            g = 255;             b = (i - 170) * 3; }
      p[i*3]=r; p[i*3+1]=g; p[i*3+2]=b;
    }
    return p;
  }
  step() {
    const { cols, rows, buf } = this;
    for (let x = 0; x < cols; x++) {
      const v = Math.random() < 0.6 ? Math.random() * 255 : 0;
      buf[(rows+1)*cols + x] = v;
      buf[(rows+2)*cols + x] = v;
    }
    for (let y = 0; y < rows; y++) {
      for (let x = 0; x < cols; x++) {
        const l = (x - 1 + cols) % cols;
        const ri = (x + 1) % cols;
        const v = (buf[(y+1)*cols+l] + buf[(y+1)*cols+x] + buf[(y+1)*cols+ri] + buf[(y+2)*cols+x]) / 4.06;
        buf[y*cols+x] = v < 0 ? 0 : v;
      }
    }
  }
  draw() {
    const { ctx, cols, rows, buf, w, h, palette } = this;
    const cw = w / cols, ch = h / rows;
    const img = ctx.createImageData(w, h);
    const d = img.data;
    for (let y = 0; y < rows; y++) {
      for (let x = 0; x < cols; x++) {
        const v = Math.min(255, Math.floor(buf[y*cols+x]));
        const r = palette[v*3], g = palette[v*3+1], b = palette[v*3+2];
        const a = v < 6 ? 0 : Math.min(255, v + 100);
        const x0 = Math.floor(x*cw), y0 = Math.floor(y*ch);
        const x1 = Math.floor((x+1)*cw), y1 = Math.floor((y+1)*ch);
        for (let py = y0; py < y1 && py < h; py++) {
          for (let px = x0; px < x1 && px < w; px++) {
            const i = (py*w+px)*4;
            d[i]=r; d[i+1]=g; d[i+2]=b; d[i+3]=a;
          }
        }
      }
    }
    ctx.putImageData(img, 0, 0);
  }
  start() {
    if (this.running) return;
    this.running = true;
    const loop = () => { if (!this.running) return; this.step(); this.draw(); requestAnimationFrame(loop); };
    loop();
  }
  stop() { this.running = false; }
}

// Initialise after layout is ready
const fires = [];
window.addEventListener('load', () => {
  document.querySelectorAll('.fire-canvas').forEach(c => fires.push(new FireCanvas(c)));
  window.addEventListener('resize', () => fires.forEach(f => f.init()));

  // Start/stop based on visibility
  const statsSection = document.getElementById('stats');
  if (!statsSection) return;

  new IntersectionObserver(entries => {
    entries.forEach(e => fires.forEach(f => e.isIntersecting ? f.start() : f.stop()));
  }, { threshold: 0.05 }).observe(statsSection);

  // Counter animation
  let counted = false;
  new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting && !counted) {
        counted = true;
        document.querySelectorAll('.stat-num').forEach(el => {
          const target = parseFloat(el.dataset.target);
          const suffix = el.dataset.suffix || '';
          const dur = 2200;
          const start = performance.now();
          const tick = now => {
            const t = Math.min((now - start) / dur, 1);
            const ease = 1 - Math.pow(1 - t, 3);
            el.textContent = Math.floor(ease * target) + suffix;
            if (t < 1) requestAnimationFrame(tick);
            else el.textContent = target + suffix;
          };
          requestAnimationFrame(tick);
        });
      }
    });
  }, { threshold: 0.3 }).observe(statsSection);
});

